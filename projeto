<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoque Residencial</title>
    <style>
        :root {
            --primary: #2c3e50;
            --accent: #27ae60;
            --warning: #e74c3c;
            --light: #f4f7f6;
        }

        body { font-family: 'Segoe UI', sans-serif; background: var(--light); margin: 0; padding-bottom: 60px; }
        header { background: var(--primary); color: white; padding: 1rem; text-align: center; }
        
        .container { padding: 15px; max-width: 600px; margin: auto; }
        .card { background: white; padding: 15px; border-radius: 8px; margin-bottom: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        
        h2 { border-bottom: 2px solid var(--accent); padding-bottom: 5px; color: var(--primary); }
        
        .form-group { margin-bottom: 10px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input, select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        
        .btn { background: var(--accent); color: white; border: none; padding: 12px; border-radius: 4px; cursor: pointer; width: 100%; font-weight: bold; }
        .btn-scan { background: #3498db; margin-bottom: 10px; }

        /* Lista de Compras em Destaque */
        .item-alerta { border-left: 5px solid var(--warning); padding: 10px; margin: 5px 0; background: #fff5f5; display: flex; justify-content: space-between; }
        .qtd-comprar { font-weight: bold; color: var(--warning); font-size: 1.2rem; }

        /* Navegação inferior (Simulação de App) */
        nav { position: fixed; bottom: 0; width: 100%; background: white; display: flex; border-top: 1px solid #ddd; }
        nav button { flex: 1; padding: 15px; border: none; background: none; font-size: 0.8rem; cursor: pointer; }
        nav button.active { color: var(--accent); font-weight: bold; }
        
        .hidden { display: none; }
    </style>
</head>
<body>

<header>
    <h1 id="app-title">Estoque Residencial</h1>
</header>

<div class="container">
    
    <section id="tela-inicial">
        <h2>🛒 O que comprar</h2>
        <div id="lista-compras">
            <div class="item-alerta">
                <div><strong>Leite Integral</strong><br><small>Marca: Piracanjuba (1L)</small></div>
                <div class="qtd-comprar">Faltam: 4</div>
            </div>
        </div>
    </section>

    <section id="tela-cadastro" class="hidden">
        <h2>🆕 Novo Produto</h2>
        <button class="btn btn-scan">📷 Escanear Código de Barras</button>
        
        <div class="form-group">
            <label>Categoria</label>
            <select id="prod-cat">
                <option>Alimentos</option>
                <option>Limpeza</option>
                <option>Higiene</option>
            </select>
        </div>
        <div class="form-group"><label>Nome</label><input type="text" placeholder="Ex: Arroz"></div>
        <div class="form-group"><label>Marca</label><input type="text" placeholder="Ex: Tio João"></div>
        <div class="form-group"><label>Medida</label><input type="text" placeholder="Ex: 5kg"></div>
        <div class="form-row" style="display:flex; gap:10px;">
            <div class="form-group" style="flex:1"><label>Estoque Atual</label><input type="number"></div>
            <div class="form-group" style="flex:1"><label>Estoque Ideal</label><input type="number"></div>
        </div>
        <div class="form-group">
            <label>Foto do Produto</label>
            <input type="file" accept="image/*" capture="environment">
        </div>
        <button class="btn">Salvar Produto</button>
    </section>

    <section id="tela-contagem" class="hidden">
        <h2>📋 Contagem de Estoque</h2>
        <div class="form-group">
            <select id="filtro-categoria">
                <option value="">Filtrar por Categoria...</option>
                <option>Alimentos</option>
                <option>Limpeza</option>
            </select>
        </div>
        <div id="itens-contagem">
            <div class="card">
                <h3>Detergente</h3>
                <p>Medida: 500ml</p>
                <label>Estoque Atual:</label>
                <input type="number" value="2" style="width: 80px; margin-bottom: 10px;">
                <button class="btn" style="background: var(--primary);">Atualizar</button>
            </div>
        </div>
    </section>
</div>

<nav>
    <button onclick="mudarTela('inicial')" class="active">INÍCIO</button>
    <button onclick="mudarTela('cadastro')">CADASTRO</button>
    <button onclick="mudarTela('contagem')">CONTAGEM</button>
</nav>

<script>
    function mudarTela(tela) {
        // Esconder todas as seções
        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        // Mostrar a selecionada
        document.getElementById('tela-' + tela).classList.remove('hidden');
        
        // Atualizar botões da nav
        document.querySelectorAll('nav button').forEach(btn => btn.classList.remove('active'));
        event.currentTarget.classList.add('active');
    }

    // Exemplo de lógica para preenchimento automático (Mock)
    document.querySelector('.btn-scan').addEventListener('click', () => {
        alert("Abrindo câmera para ler código de barras...");
        // Aqui entraria a lógica de API de produtos
    });
</script>

</body>
</html>
